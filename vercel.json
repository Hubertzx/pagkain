{
  "version": 2,
  "name": "lutong-pinoy",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/assets/video/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable",
        "Accept-Ranges": "bytes"
      },
      "dest": "/assets/video/$1"
    },
    {
      "src": "/assets/images/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}